<!DOCTYPE html>
<html lang="<%= config.language || 'en' %>">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (locals.title || '').toUpperCase() %></title>
  <meta name="description" content="<%= locals.description || '' %>">
  <link rel="canonical" href="<%= locals.currentUrl || '' %>">

  <%
    /* ── Computed SEO values ─────────────────────────────── */
    var _seqTitle       = (locals.title || '') + ' - ' + (locals.siteName || '');
    var _seqDesc        = locals.description || config.defaultDescription || '';
    var _seqUrl         = locals.currentUrl || '';
    var _seqSiteName    = locals.siteName || config.siteName || '';
    var _seqLocale      = (config.language || 'en').replace('-', '_');
    if (_seqLocale.length < 4) _seqLocale = _seqLocale + '_US'; // e.g. en → en_US
    var _seqIsArticle   = (locals.schema === 'article');
    var _seqOgType      = _seqIsArticle ? 'article' : 'website';

    /* OG Image: static file hosted on own domain → Google indexes under site's domain, not bing.com */
    var _seqBaseUrl     = locals.baseUrl || '';
    var _seqImage       = _seqBaseUrl + '/images/og-preview.jpg';

    /* news_keywords from article.related_keywords */
    var _seqNewsKw = '';
    if (_seqIsArticle && locals.article && locals.article.related_keywords && locals.article.related_keywords.length > 0) {
      _seqNewsKw = locals.article.related_keywords.slice(0, 10).join(', ');
    }
  %>

  <!-- ── Robots ───────────────────────────────────────────── -->
  <% if (_seqIsArticle) { %>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <% } else { %>
  <meta name="robots" content="index, follow">
  <% } %>

  <!-- ── Publisher ────────────────────────────────────────── -->
  <meta name="publisher" content="<%= _seqSiteName %>">

  <!-- ── News Keywords (article pages only) ───────────────── -->
  <% if (_seqNewsKw) { %>
  <meta name="news_keywords" content="<%= _seqNewsKw %>">
  <% } %>

  <!-- ── Open Graph ───────────────────────────────────────── -->
  <meta property="og:locale"       content="<%= _seqLocale %>">
  <meta property="og:type"         content="<%= _seqOgType %>">
  <meta property="og:title"        content="<%= _seqTitle %>">
  <meta property="og:description"  content="<%= _seqDesc %>">
  <meta property="og:url"          content="<%= _seqUrl %>">
  <meta property="og:site_name"    content="<%= _seqSiteName %>">
  <meta property="og:image"        content="<%= _seqImage %>">
  <meta property="og:image:width"  content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type"   content="image/jpeg">
  <% if (_seqIsArticle) { %>
  <meta property="article:published_time" content="<%= new Date().toISOString() %>">
  <meta property="article:section"        content="<%= (locals.f1 || '') %>">
  <% if (_seqNewsKw) { %>
  <meta property="article:tag"            content="<%= _seqNewsKw %>">
  <% } %>
  <% } %>

  <!-- ── Twitter Card ─────────────────────────────────────── -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="<%= _seqTitle %>">
  <meta name="twitter:description" content="<%= _seqDesc %>">
  <meta name="twitter:image"       content="<%= _seqImage %>">
  <meta name="twitter:image:alt"   content="<%= locals.title || '' %>">

  <!-- SEO Meta Tags -->
  <% if (locals.config && config.googleVerification) { %>
    <meta name="google-site-verification" content="<%= config.googleVerification %>">
  <% } %>
  <% if (locals.config && config.bingVerification) { %>
    <meta name="msvalidate.01" content="<%= config.bingVerification %>">
  <% } %>

  <!-- Fonts and Styles -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- ── Favicons ─────────────────────────────────────────── -->
  <link rel="icon"             type="image/png"  href="/favicon.png?v=2">
  <link rel="shortcut icon"    type="image/x-icon" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180"  href="/apple-touch-icon.png">
  <meta name="theme-color"     content="<%= (locals.activeTheme && locals.activeTheme.accent) ? locals.activeTheme.accent : '#6c5ce7' %>">
  <link rel="stylesheet" href="/css/style.css?v=1.9">
  
  <!-- Dynamic Theme Variables -->
  <% if (locals.activeTheme) { %>
  <style>
    :root {
      --bg-primary: <%= activeTheme.bgPrimary %>;
      --bg-secondary: <%= activeTheme.bgSecondary %>;
      --bg-card: <%= activeTheme.bgCard %>;
      --text-primary: <%= activeTheme.textPrimary %>;
      --text-secondary: <%= activeTheme.textSecondary %>;
      --text-muted: <%= activeTheme.textMuted %>;
      --accent: <%= activeTheme.accent %>;
      --accent-light: <%= activeTheme.accentLight %>;
      --accent-glow: <%= activeTheme.accentGlow %>;
      --accent-gradient: <%= activeTheme.gradient %>;
    }
  </style>
  <% } %>

  <%- include('../partials/schema') %>

            <!-- Google Analytics -->
            <% if (config.googleAnalyticsId) { %>
              <script async src="https://www.googletagmanager.com/gtag/js?id=<%= config.googleAnalyticsId %>"></script>
              <script>
                window.dataLayer = window.dataLayer || [];
                function gtag() { dataLayer.push(arguments); }
                gtag('js', new Date());
                gtag('config', '<%= config.googleAnalyticsId %>');
              </script>
              <% } %>
</head>

<body class="path-<%= currentPath.replace(/\//g, '-' ).substring(1) || 'home' %>">
  <%- include('../partials/header') %>

    <main class="main-content">
      <%- typeof body !== 'undefined' ? body : (typeof contentBlock !== 'undefined' ? contentBlock : '') %>
    </main>

    <%- include('../partials/footer') %>
    
    <!-- Security Modal (I'm Human) -->
    <div class="security-overlay" id="securityOverlay">
      <div class="security-modal">
        <div class="security-icon">
          <i class="fas fa-user-shield"></i>
        </div>
        <h2 class="security-title">Security Check</h2>
        <p class="security-text">
          Please verify that you are a human to continue access to our premium content. 
          This helps us prevent automated bot activity.
        </p>
        <button class="btn-security" id="btnVerify">I'm a Human</button>
      </div>
    </div>

    <!-- Global Ad Slots -->
    <% if (config.ads.enabled) { %>
      <div class="global-ads">
        <%- config.ads.socialBar %>
      </div>
    <% } %>

    <!-- Global Scripts & Security Logic -->
    <script>
      (function() {
        // Configuration from Server
        const popupConfig = JSON.parse('<%- JSON.stringify(config.ads.popup) %>');
        const directLink  = '<%= config.ads.directLinkUrl %>';

        const overlay = document.getElementById('securityOverlay');
        const btn     = document.getElementById('btnVerify');

        const STORAGE_KEY     = 'agc_hv';                          // localStorage key
        const COOLDOWN_MS     = (popupConfig.cooldownHours || 24)  // jam → ms
                                * 60 * 60 * 1000;

        /** Cek apakah user sudah verify dalam window cooldown */
        function isVerified() {
          try {
            var ts = localStorage.getItem(STORAGE_KEY);
            if (!ts) return false;
            return (Date.now() - parseInt(ts, 10)) < COOLDOWN_MS;
          } catch(e) {
            return false; // private mode / localStorage disabled
          }
        }

        /** Simpan timestamp verifikasi ke localStorage */
        function markVerified() {
          try {
            localStorage.setItem(STORAGE_KEY, Date.now().toString());
          } catch(e) { /* silent */ }
        }

        function showPopup() {
          if (overlay) overlay.style.display = 'flex';
        }

        function hidePopup() {
          if (overlay) overlay.style.display = 'none';
        }

        function initSecurity() {
          if (!popupConfig.enabled) return;

          // Jika user sudah verify dalam cooldown → skip, jangan tampilkan
          if (isVerified()) return;

          // Tampilkan setelah 500ms agar konten halaman sempat terlihat
          setTimeout(showPopup, 500);
        }

        if (btn && overlay) {
          btn.addEventListener('click', function() {
            // 1. Buka link iklan / verifikasi di tab baru
            window.open(directLink, '_blank');
            // 2. Simpan timestamp → tidak akan muncul lagi sampai cooldown habis
            markVerified();
            // 3. Tutup modal
            hidePopup();
          });
        }

        // Initialize
        initSecurity();
      })();
    </script>
    
    <!-- FontAwesome for Security Icon -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Histats Tracking (Situs & Global) -->
          <script type="text/javascript">
            var h_situs = '<%= (locals.config && config.ST_ID_Situs) ? config.ST_ID_Situs : "" %>';
            var h_global = '<%= (locals.config && config.ST_ID_Global) ? config.ST_ID_Global : "" %>';
            var _Hasync = _Hasync || [];
            
            if (h_situs) {
              _Hasync.push(['Histats.start', '1,' + h_situs + ',4,0,0,0,00010000']);
              _Hasync.push(['Histats.fasi', '1']);
              _Hasync.push(['Histats.track_hits', '']);
            }
            if (h_global) {
              _Hasync.push(['Histats.start', '1,' + h_global + ',4,0,0,0,00010000']);
              _Hasync.push(['Histats.fasi', '1']);
              _Hasync.push(['Histats.track_hits', '']);
            }

            (function() {
              var hs = document.createElement('script'); hs.type = 'text/javascript'; hs.async = true;
              hs.src = ('//s10.histats.com/js15_as.js');
              (document.getElementsByTagName('head')[0] || document.getElementsByTagName('body')[0]).appendChild(hs);
            })();
          </script>
          <noscript>
            <% if (locals.config && config.ST_ID_Situs) { %><a href="/" target="_blank"><img src="//sstatic1.histats.com/0.gif?<%= config.ST_ID_Situs %>&101" alt="stats" border="0"></a><% } %>
            <% if (locals.config && config.ST_ID_Global) { %><a href="/" target="_blank"><img src="//sstatic1.histats.com/0.gif?<%= config.ST_ID_Global %>&101" alt="stats" border="0"></a><% } %>
          </noscript>

</body>

</html>