<% 
// 1. Data Preparation
var galleryImages = []; 
var imgKeywords = []; 
// Use the primary keyword for images
imgKeywords.push(title);
if (internalResults && internalResults.length > 0) {
  for (var rk = 0; rk < internalResults.length && imgKeywords.length < 8; rk++) { 
    imgKeywords.push(internalResults[rk].keyword); 
  } 
} 
while (imgKeywords.length < 8) { imgKeywords.push(title); } 

// URL suffixes: same pattern as PHP native for diversity
var _sfx = ['', '+1', '+info', '+gallery', '+photo', '+view', '+detail', '+read'];

for (var gi = 0; gi < 8; gi++) { 
  var _bq = encodeURIComponent(imgKeywords[gi]).replace(/%20/g, '+') + _sfx[gi];
  galleryImages.push({ 
    thumb: 'https://tse1.mm.bing.net/th?q=' + _bq + '&pid=Api&mkt=en-US&adlt=moderate', 
    full:  'https://tse1.mm.bing.net/th?q=' + _bq + '&pid=Api&mkt=en-US&adlt=moderate&w=1200&h=630', 
    alt: imgKeywords[gi] 
  }); 
} 

// 2. Build ContentBlock
var html = [];
html.push("<article class='article-page generated-page' id='article-page'>");
html.push("<div class='container article-container'>");

// Breadcrumbs Use URL parts
html.push("<nav class='breadcrumb' aria-label='Breadcrumb'>");
html.push("<a href='/'>Home</a><span class='sep'>›</span>");
if (f1) html.push("<a href='/page/" + f1 + "'>" + f1 + "</a><span class='sep'>›</span>");
if (f2) html.push("<a href='/page/" + f1 + "/" + f2 + "'>" + f2 + "</a><span class='sep'>›</span>");
html.push("<span class='current'>" + title + "</span>");
html.push("</nav>");

html.push("<header class='article-header'>");
html.push("<h1 class='article-title' id='article-title'>" + title + "</h1>");
html.push("<p class='article-subtitle'>Real-time summary and related information.</p>");
html.push("</header>");

if (config.ads.enabled && !isSpeedBot) { html.push(config.ads.bannerUnderTitle || ""); }

// Generated Main Content from Snippets
html.push("<div class='article-content' id='article-content'>");
html.push("<div class='summary-box'><strong>Web Update:</strong> Latest findings for " + title + ".</div>");

if (webResults && webResults.length > 0) {
  webResults.forEach(function(res, i) {
    html.push("<div class='snippet-item' style='margin-bottom: 30px;'>");
    html.push("<h2 style='font-size: 1.4rem; color: #3498db; margin-bottom: 10px;'>" + res.title + "</h2>");
    html.push("<p style='line-height: 1.8; color: #444;'>" + res.snippet + "</p>");
    html.push("</div>");
    
    // Inject mid-article ads if enabled
    if (i === 1 && config.ads.enabled && !isSpeedBot) html.push(config.ads.bannerMidArticle || ""); 
  });
} else {
  html.push("<p>We are currently gathering the latest details for " + title + ". Please check back shortly or explore the related topics below.</p>");
}
html.push("</div>");

if (config.ads.enabled && !isSpeedBot) { html.push(config.ads.bannerUnderArticle || ""); }

// Image Gallery
html.push("<section class='image-gallery' id='image-gallery'>");
html.push("<h2 class='gallery-title'>📸 Image Insights</h2>");
html.push("<div class='gallery-grid'>");
galleryImages.forEach(function(img, idx) {
  html.push("<figure class='gallery-item'>");
  html.push("<a href='" + img.full + "' onclick='event.preventDefault(); openLightbox(" + idx + ")' title='View " + img.alt + "'>");
  html.push("<div class='img-wrap'><img src='" + img.thumb + "' alt='" + img.alt + "' loading='lazy' width='400' height='400'></div>");
  html.push("<figcaption>" + img.alt + "</figcaption></a></figure>");
});
html.push("</div></section>");

// Related Content (Internal)
if (internalResults && internalResults.length > 0) {
  html.push("<section class='related-section' id='related-section'>");
  html.push("<h2 class='section-title'>Internal Related Content</h2>");
  html.push("<div class='related-grid'>");
  internalResults.forEach(function(r) {
    var _rUrl = getRedirectUrl(buildArticleUrl(r.f1, r.f2, r.code, r.keyword), r.keyword);
    html.push("<a href='" + _rUrl + "' class='related-card'>");
    html.push("<span class='related-cat'>" + r.f1 + "/" + r.f2 + "</span>");
    html.push("<h3>" + r.keyword + "</h3><span class='card-action'>Read more →</span></a>");
  });
  html.push("</div></section>");
}

html.push("</div></article>");

// Lightbox Logic (Copied from article.ejs)
html.push("<div class='lightbox-overlay' id='lightbox-overlay' onclick='closeLightbox(event)'>");
html.push("<div class='lightbox-inner'><button class='lightbox-close' onclick='closeLightbox(event)' aria-label='Close'>&times;</button>");
html.push("<div class='lightbox-content-wrap'>"); 
html.push("<button class='lightbox-prev' onclick='prevImage(event)' aria-label='Previous'>‹</button>");
html.push("<img class='lightbox-img' id='lightbox-img' src='' alt=''>");
html.push("<button class='lightbox-next' onclick='nextImage(event)' aria-label='Next'>›</button>");
html.push("</div><p class='lightbox-caption' id='lightbox-caption'></p></div></div>");

html.push("<" + "script" + ">");
html.push("var galleryData = " + JSON.stringify(galleryImages) + ";");
html.push("var currentIdx = 0;");
html.push("function openLightbox(idx) { currentIdx = idx; var lb = document.getElementById('lightbox-overlay'); var img = document.getElementById('lightbox-img'); var cap = document.getElementById('lightbox-caption'); img.src = galleryData[idx].full; img.alt = galleryData[idx].alt; cap.textContent = galleryData[idx].alt; lb.classList.add('active'); document.body.style.overflow = 'hidden'; } ");
html.push("function closeLightbox(e) { if (e.target === document.getElementById('lightbox-overlay') || e.target.classList.contains('lightbox-close')) { document.getElementById('lightbox-overlay').classList.remove('active'); document.body.style.overflow = ''; } } ");
html.push("function prevImage(e) { e.stopPropagation(); currentIdx = (currentIdx - 1 + galleryData.length) % galleryData.length; openLightbox(currentIdx); } ");
html.push("function nextImage(e) { e.stopPropagation(); currentIdx = (currentIdx + 1) % galleryData.length; openLightbox(currentIdx); } ");
html.push("</" + "script" + ">");

var cb = html.join("");
%>
<%- include("../layouts/main", { contentBlock: cb }) %>
