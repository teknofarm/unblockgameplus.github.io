<% 
var html = [];

// Partition articles for News/Magazine Layout
var headline = articles.length > 0 ? articles[0] : null;
var trending = articles.length > 1 ? articles.slice(1, 6) : []; // 5 articles
var feed = articles.length > 6 ? articles.slice(6) : [];

// Safe thumbnail generator function
function getThumb(keyword, w, h) {
  return "https://www.bing.com/th?q=" + encodeURIComponent(keyword) + "&w=" + w + "&h=" + h + "&c=7&pid=1.7";
}

html.push(`
<style>
/* =========================================
   V3 HOMEPAGE: NEWS/BLOG HYBRID
   ========================================= */
.v3-body {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  padding-bottom: 60px;
}
.v3-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Typography & General */
.v3-section-title {
  font-size: 1.5rem;
  font-weight: 800;
  border-bottom: 2px solid var(--accent);
  padding-bottom: 10px;
  margin-bottom: 24px;
  position: relative;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.v3-section-title::after {
  content: '';
  position: absolute;
  bottom: -2px; left: 0;
  width: 100%; height: 2px;
  background: var(--bg-card);
  z-index: -1;
}

/* Badge/Labels */
.v3-cat-badge {
  display: inline-block;
  background: var(--accent);
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 4px;
  text-transform: uppercase;
  text-decoration: none;
  margin-bottom: 12px;
  transition: opacity 0.3s ease;
}
.v3-cat-badge:hover { opacity: 0.85; }

/* --- Search Bar Top --- */
.v3-top-search {
  padding: 120px 20px 50px;
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--bg-card);
  margin-bottom: 40px;
}
.v3-search-form {
  max-width: 800px;
  margin: 0 auto;
  display: flex;
  position: relative;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  border: 1px solid var(--bg-card);
}
.v3-search-input {
  flex: 1;
  padding: 16px 20px;
  border: none;
  outline: none;
  background: var(--bg-primary);
  color: var(--text-primary);
  font-size: 1.1rem;
}
.v3-search-btn {
  background: var(--accent);
  color: #fff;
  border: none;
  padding: 0 30px;
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  transition: filter 0.3s ease;
}
.v3-search-btn:hover { filter: brightness(1.1); }

/* --- Headline --- */
.v3-headline {
  margin-bottom: 50px;
}
.v3-headline-card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  background: var(--bg-secondary);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  border: 1px solid var(--bg-card);
  transition: transform 0.3s ease;
}
.v3-headline-card:hover { transform: translateY(-4px); border-color: var(--accent); }
.v3-headline-img {
  width: 100%;
  height: 400px;
  object-fit: cover;
  background: var(--bg-card);
}
.v3-headline-content {
  padding: 30px;
}
.v3-headline-title {
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 15px;
  color: var(--text-primary);
}
.v3-headline-desc {
  font-size: 1.1rem;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* --- Layout Grid --- */
.v3-layout {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 40px;
}
@media (max-width: 900px) {
  .v3-layout { grid-template-columns: 1fr; }
}

/* --- Blog Feed --- */
.v3-feed-list {
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.v3-feed-item {
  display: flex;
  gap: 20px;
  text-decoration: none;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--bg-card);
  transition: background 0.3s ease;
}
.v3-feed-item:hover .v3-feed-title { color: var(--accent); }
.v3-feed-img {
  width: 200px;
  height: 140px;
  object-fit: cover;
  border-radius: 8px;
  flex-shrink: 0;
  background: var(--bg-card);
}
@media (max-width: 600px) {
  .v3-feed-item { flex-direction: column; }
  .v3-feed-img { width: 100%; height: 200px; }
}
.v3-feed-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.v3-feed-title {
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: 12px;
  transition: color 0.3s ease;
}
.v3-feed-action {
  font-size: 0.9rem;
  color: var(--text-muted);
  font-weight: 600;
  margin-top: auto;
}

/* --- Sidebar Tools --- */
.v3-sidebar {
  display: flex;
  flex-direction: column;
  gap: 40px;
}
.v3-widget {
  background: var(--bg-secondary);
  padding: 24px;
  border-radius: 12px;
  border: 1px solid var(--bg-card);
}
.v3-trending-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.v3-trending-item {
  display: flex;
  gap: 12px;
  text-decoration: none;
  align-items: flex-start;
}
.v3-trending-item:not(:last-child) {
  border-bottom: 1px solid var(--bg-card);
  padding-bottom: 16px;
}
.v3-trending-number {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--accent-light);
  opacity: 0.5;
  line-height: 1;
}
.v3-trending-title {
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  transition: color 0.3s ease;
}
.v3-trending-item:hover .v3-trending-title { color: var(--accent); }

.v3-cat-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.v3-cat-link {
  background: var(--bg-card);
  color: var(--text-primary);
  padding: 8px 14px;
  border-radius: 20px;
  font-size: 0.85rem;
  text-decoration: none;
  transition: all 0.3s ease;
  border: 1px solid transparent;
}
.v3-cat-link:hover {
  background: var(--accent-glow);
  color: var(--accent-light);
  border-color: var(--accent);
}

/* Pagination */
.v3-pagination {
  margin-top: 40px;
  display: flex;
  gap: 15px;
  align-items: center;
}
.v3-page-btn {
  background: var(--bg-secondary);
  color: var(--text-primary);
  padding: 10px 20px;
  border: 1px solid var(--bg-card);
  border-radius: 6px;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
}
.v3-page-btn:hover:not(.disabled) {
  background: var(--accent);
  color: #fff;
}
.v3-page-btn.disabled { opacity: 0.5; cursor: not-allowed; }
.v3-page-info { color: var(--text-secondary); font-size: 0.95rem; }
</style>
<div class="v3-body">

  <!-- Search Header -->
  <div class="v3-top-search">
    <div class="v3-container">
      <form action="/search" method="GET" class="v3-search-form">
        <input type="text" name="q" class="v3-search-input" placeholder="Search news, guides, and articles..." required>
        <button type="submit" class="v3-search-btn">Search</button>
      </form>
    </div>
  </div>

  <div class="v3-container">
`);

if (headline) {
  html.push(`
    <!-- Headline Section -->
    <div class="v3-headline">
      <h2 class="v3-section-title">Headline News</h2>
      <a href="${headline.url}" class="v3-headline-card">
        <img src="${getThumb(headline.keyword, 1200, 400)}" class="v3-headline-img" alt="${headline.keyword}" loading="lazy">
        <div class="v3-headline-content">
          <span class="v3-cat-badge">${headline.f1}</span>
          <h3 class="v3-headline-title">${headline.keyword}</h3>
          <p class="v3-headline-desc">Discover the full story... Click to read more about ${headline.keyword} and explore deeper insights on this topic.</p>
        </div>
      </a>
    </div>
  `);
}

html.push(`
    <!-- Main Layout Grid -->
    <div class="v3-layout">
      <!-- Left: Blog Feed -->
      <div class="v3-main-col">
        <h2 class="v3-section-title">Latest Articles</h2>
        <div class="v3-feed-list">
`);

feed.forEach(function(a) {
  html.push(`
          <a href="${a.url}" class="v3-feed-item">
            <img src="${getThumb(a.keyword, 400, 280)}" class="v3-feed-img" alt="${a.keyword}" loading="lazy">
            <div class="v3-feed-content">
              <span class="v3-cat-badge" style="background: var(--bg-card); color: var(--accent-light); margin-bottom: 8px;">${a.f1}</span>
              <h4 class="v3-feed-title">${a.keyword}</h4>
              <span class="v3-feed-action">Read Full Article →</span>
            </div>
          </a>
  `);
});

// Pagination
if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) {
  html.push(`
          <div class="v3-pagination">
            ${pagination.hasPrev ? `<a href="${pagination.prevUrl}" class="v3-page-btn">←</a>` : `<span class="v3-page-btn disabled">←</span>`}
            <span class="v3-page-info">Page <strong>${pagination.page}</strong> / ${pagination.totalPages.toLocaleString()}</span>
            ${pagination.hasNext ? `<a href="${pagination.nextUrl}" class="v3-page-btn">→</a>` : `<span class="v3-page-btn disabled">→</span>`}
          </div>
  `);
}

html.push(`
        </div>
      </div> <!-- End Main Col -->

      <!-- Right: Sidebar -->
      <aside class="v3-sidebar">
        
        <!-- Widget: Trending -->
        <div class="v3-widget">
          <h2 class="v3-section-title" style="font-size:1.2rem; border-color:var(--accent-light);">Trending Topics</h2>
          <div class="v3-trending-list">
`);

trending.forEach(function(t, idx) {
  html.push(`
            <a href="${t.url}" class="v3-trending-item">
              <span class="v3-trending-number">${idx + 1}</span>
              <span class="v3-trending-title">${t.keyword}</span>
            </a>
  `);
});

html.push(`
          </div>
        </div>
        
        <!-- Widget: Categories -->
        <div class="v3-widget">
          <h2 class="v3-section-title" style="font-size:1.2rem;">Directories</h2>
          <div class="v3-cat-list">
`);

folders.forEach(function(f) {
  html.push(`<a href="/page/${f.f1}" class="v3-cat-link">${f.f1.toUpperCase()}</a>`);
});

html.push(`
          </div>
        </div>

      </aside>
    </div> <!-- End Layout -->
  </div> <!-- End Container -->
</div> <!-- End Body -->
`);

var cb = html.join('\n');
%>
<%- include('../layouts/main', { contentBlock: cb }) %>
