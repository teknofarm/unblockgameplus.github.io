<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="logo" id="logo">
      <span class="logo-icon">◆</span>
      <span class="logo-text"><%= siteName %></span>
    </a>

    <nav class="nav-main" id="nav-main">
      <a href="/" class="nav-link<%= currentPath === '/' ? ' active' : '' %>">Home</a>
      <a href="/search" class="nav-link<%= currentPath === '/search' ? ' active' : '' %>">Search</a>
    </nav>

    <div class="header-actions">
      <form action="/search" method="GET" class="search-mini" id="search-mini">
        <input type="text" name="q" placeholder="Search..." autocomplete="off" aria-label="Search">
        <button type="submit" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
      </form>

      <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu">
    <form action="/search" method="GET" class="search-mobile">
      <input type="text" name="q" placeholder="Search articles..." autocomplete="off">
      <button type="submit">Search</button>
    </form>
    <a href="/" class="mobile-link">Home</a>
    <a href="/search" class="mobile-link">Search</a>
  </div>
</header>
<!-- Reading progress bar -->
<div class="reading-progress" id="reading-progress"></div>
