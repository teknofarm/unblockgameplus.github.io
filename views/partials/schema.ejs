<%
/**
 * Schema JSON-LD Generator — Full SEO Schema Suite
 * Matches the PHP master schema setup:
 * NewsArticle, Article, WebPage, BreadcrumbList, QAPage, FAQPage
 */
%>

<% if (schema === 'website') { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "<%= siteName %>",
  "url": "<%= baseUrl %>",
  "description": "<%= (typeof description !== 'undefined' ? description : '').replace(/"/g, '\\"') %>",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "<%= baseUrl %>/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  },
  "publisher": {
    "@type": "Organization",
    "name": "<%= siteName %>",
    "url": "<%= baseUrl %>"
  }
}
</script>
<% } %>

<% if (schema === 'article' && typeof article !== 'undefined') { %>
<%
  var artTitle = (article.title || '').replace(/"/g, '\\"').replace(/\n/g, ' ');
  var artDesc = (typeof description !== 'undefined' ? description : '').replace(/"/g, '\\"').replace(/\n/g, ' ');
  var altHeadline = '';
  if (article.description_alt) {
    altHeadline = article.description_alt.replace(/<[^>]+>/g, '').replace(/"/g, '\\"').replace(/\n/g, ' ').substring(0, 100);
  }
  var newsKeywords = '';
  if (article.related_keywords && article.related_keywords.length > 0) {
    newsKeywords = article.related_keywords.slice(0, 10).join(', ').replace(/"/g, '\\"');
  }
  var canonUrl = baseUrl + (typeof canonicalPath !== 'undefined' && canonicalPath ? canonicalPath : currentPath);
%>

<%# === 1. NewsArticle === %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": "<%= artTitle %>",
  "alternativeHeadline": "<%= altHeadline %>",
  "description": "<%= artDesc %>",
  "keywords": "<%= newsKeywords %>",
  "image": {
    "@type": "ImageObject",
    "url": "<%= baseUrl %>/images/og-preview.jpg",
    "width": 1200,
    "height": 630
  },
  "datePublished": "<%= new Date(Date.now() - 60*24*60*60*1000).toISOString() %>",
  "dateModified": "<%= new Date().toISOString() %>",
  "author": {
    "@type": "Organization",
    "name": "Professional Insights Editorial",
    "url": "<%= baseUrl %>"
  },
  "publisher": {
    "@type": "Organization",
    "name": "<%= siteName %>",
    "logo": {
      "@type": "ImageObject",
      "url": "<%= baseUrl %>/images/logo.png",
      "width": 600,
      "height": 60
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "<%= canonUrl %>"
  },
  "isAccessibleForFree": true
}
</script>

<%# === 2. Article === %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "<%= artTitle %>",
  "image": "<%= baseUrl %>/images/og-preview.jpg",
  "author": {
    "@type": "Organization",
    "name": "Content Research Bureau"
  },
  "publisher": {
    "@type": "Organization",
    "name": "<%= siteName %>"
  },
  "datePublished": "<%= new Date(Date.now() - 60*24*60*60*1000).toISOString() %>",
  "dateModified": "<%= new Date().toISOString() %>"
}
</script>

<%# === 3. WebPage === %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "<%= canonUrl %>",
  "name": "<%= artTitle %>",
  "description": "<%= artDesc %>",
  "publisher": {
    "@type": "Organization",
    "name": "<%= siteName %>"
  }
}
</script>

<%# === 4. BreadcrumbList === %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "<%= baseUrl %>"},
    {"@type": "ListItem", "position": 2, "name": "<%= f1 %>", "item": "<%= baseUrl %>/<%= f1 %>"},
    {"@type": "ListItem", "position": 3, "name": "<%= f2 %>", "item": "<%= baseUrl %>/<%= f1 %>/<%= f2 %>"},
    {"@type": "ListItem", "position": 4, "name": "<%= artTitle %>", "item": "<%= canonUrl %>"}
  ]
}
</script>

<%# === 5. QAPage (main question + suggested answers) === %>
<% if (article.questions && article.questions.length > 0) {
  var mainQ = article.questions[0];
  var mainQText = (mainQ.question || '').replace(/"/g, '\\"').replace(/\n/g, ' ');
  var mainAText = (mainQ.answer || '').replace(/<[^>]+>/g, '').replace(/"/g, '\\"').replace(/\n/g, ' ');
%>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "QAPage",
  "mainEntity": {
    "@type": "Question",
    "name": "<%= mainQText %>",
    "text": "<%= mainQText %>",
    "answerCount": <%= article.questions.length %>,
    "author": {
      "@type": "Organization",
      "name": "Professional Content Bureau",
      "url": "<%= baseUrl %>"
    },
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "<%= mainAText %>",
      "upvoteCount": <%= Math.floor(Math.random() * 150) + 50 %>,
      "url": "<%= canonUrl %>#faq-0",
      "author": {
        "@type": "Organization",
        "name": "News Network Editorial",
        "url": "<%= baseUrl %>"
      }
    }<% if (article.questions.length > 1) { %>,
    "suggestedAnswer": [
      <% article.questions.slice(1).forEach(function(sq, si) {
        var sqA = (sq.answer || '').replace(/<[^>]+>/g, '').replace(/"/g, '\\"').replace(/\n/g, ' ');
      %><%= si > 0 ? ',' : '' %>
      {
        "@type": "Answer",
        "text": "<%= sqA %>",
        "upvoteCount": <%= Math.floor(Math.random() * 44) + 5 %>,
        "url": "<%= canonUrl %>#faq-<%= si + 1 %>",
        "author": {
          "@type": "Organization",
          "name": "Content Verification Bureau",
          "url": "<%= baseUrl %>"
        }
      }
      <% }); %>
    ]
    <% } %>
  }
}
</script>

<%# === 6. Individual QAPage per question === %>
<% article.questions.forEach(function(iq, ii) {
  var iqQ = (iq.question || '').replace(/"/g, '\\"').replace(/\n/g, ' ');
  var iqA = (iq.answer || '').replace(/<[^>]+>/g, '').replace(/"/g, '\\"').replace(/\n/g, ' ');
%>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "QAPage",
  "mainEntity": {
    "@type": "Question",
    "name": "<%= iqQ %>",
    "text": "<%= iqQ %>",
    "answerCount": 1,
    "author": {
      "@type": "Organization",
      "name": "Professional Insights",
      "url": "<%= baseUrl %>"
    },
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "<%= iqA %>",
      "upvoteCount": <%= Math.floor(Math.random() * 90) + 10 %>,
      "url": "<%= canonUrl %>#faq-<%= ii %>",
      "author": {
        "@type": "Organization",
        "name": "Editorial Staff",
        "url": "<%= baseUrl %>"
      }
    }
  }
}
</script>
<% }); %>

<%# === 7. FAQPage === %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    <% article.questions.forEach(function(fq, fi) {
      var fqQ = (fq.question || '').replace(/"/g, '\\"').replace(/\n/g, ' ');
      var fqA = (fq.answer || '').replace(/<[^>]+>/g, '').replace(/"/g, '\\"').replace(/\n/g, ' ');
    %><%= fi > 0 ? ',' : '' %>
    {
      "@type": "Question",
      "name": "<%= fqQ %>",
      "text": "<%= fqQ %>",
      "answerCount": 1,
      "author": {
        "@type": "Organization",
        "name": "Professional Insights",
        "url": "<%= baseUrl %>"
      },
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "<%= fqA %>",
        "upvoteCount": <%= Math.floor(Math.random() * 90) + 10 %>,
        "url": "<%= canonUrl %>#faq-<%= fi %>",
        "author": {
          "@type": "Organization",
          "name": "Editorial Staff",
          "url": "<%= baseUrl %>"
        }
      }
    }
    <% }); %>
  ]
}
</script>
<% } %>
<% } %>

<% if (schema === 'category') { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "<%= (typeof title !== 'undefined' ? title : '').replace(/"/g, '\\"') %>",
  "description": "<%= (typeof description !== 'undefined' ? description : '').replace(/"/g, '\\"') %>",
  "url": "<%= currentUrl %>",
  "isPartOf": {
    "@type": "WebSite",
    "name": "<%= siteName %>",
    "url": "<%= baseUrl %>"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "<%= baseUrl %>"}
      <% if (typeof f1 !== 'undefined' && f1) { %>
      ,{"@type": "ListItem", "position": 2, "name": "<%= f1 %>", "item": "<%= baseUrl %>/<%= f1 %>"}
      <% } %>
      <% if (typeof f2 !== 'undefined' && f2) { %>
      ,{"@type": "ListItem", "position": 3, "name": "<%= f2 %>", "item": "<%= baseUrl %>/<%= f1 %>/<%= f2 %>"}
      <% } %>
    ]
  }
}
</script>
<% } %>

<% if (schema === 'search') { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SearchResultsPage",
  "name": "<%= (typeof title !== 'undefined' ? title : '').replace(/"/g, '\\"') %>",
  "url": "<%= currentUrl %>",
  "isPartOf": {
    "@type": "WebSite",
    "name": "<%= siteName %>",
    "url": "<%= baseUrl %>"
  }
}
</script>
<% } %>
