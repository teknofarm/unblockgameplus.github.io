<% 
var html = [];

// 1. Inject Styles
html.push(`
<style>
/* =========================================
   V2 HOMEPAGE: PREMIUM DESIGN SYSTEM
   ========================================= */
.v2-hero {
  position: relative;
  overflow: hidden;
  padding: 120px 20px 100px;
  text-align: center;
  background: var(--bg-primary);
  border-bottom: 1px solid var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
}
.v2-hero::before {
  content: '';
  position: absolute;
  top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(circle at center, var(--accent-glow) 0%, transparent 60%);
  animation: v2-pulse 8s infinite alternate ease-in-out;
  pointer-events: none;
  z-index: 0;
}
@keyframes v2-pulse {
  0% { transform: scale(1) translate(0,0); }
  100% { transform: scale(1.1) translate(2%, 2%); }
}
.v2-hero-content {
  position: relative;
  z-index: 1;
  max-width: 900px;
  margin: 0 auto;
}
.v2-hero-title {
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 24px;
  color: var(--text-primary);
  letter-spacing: -1.5px;
}
.v2-hero-title .hg {
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  color: transparent;
  display: inline-block;
}
.v2-hero-subtitle {
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  color: var(--text-secondary);
  margin-bottom: 48px;
  font-weight: 400;
  max-width: 700px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.6;
}
.v2-search-form {
  position: relative;
  max-width: 650px;
  margin: 0 auto;
}
.v2-search-wrapper {
  display: flex;
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.05);
  padding: 10px 10px 10px 28px;
  border-radius: 60px;
  align-items: center;
  box-shadow: 0 15px 35px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.1);
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}
.v2-search-wrapper:focus-within {
  border-color: var(--accent-light);
  box-shadow: 0 15px 45px var(--accent-glow), inset 0 1px 0 rgba(255,255,255,0.1);
  transform: translateY(-3px);
}
.v2-search-input {
  flex: 1;
  border: none;
  background: transparent;
  color: var(--text-primary);
  font-size: 1.15rem;
  outline: none;
  font-family: inherit;
  padding-left: 12px;
}
.v2-search-input::placeholder {
  color: var(--text-muted);
}
.v2-search-btn {
  background: var(--accent-gradient);
  border: none;
  color: #fff;
  padding: 14px 36px;
  border-radius: 50px;
  font-size: 1.05rem;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
  box-shadow: 0 5px 15px var(--accent-glow);
}
.v2-search-btn:hover {
  opacity: 0.95;
  transform: translateY(-1px) scale(1.02);
  box-shadow: 0 8px 25px var(--accent-glow);
}

/* --- Section Areas --- */
.v2-section {
  padding: 100px 20px;
  background: var(--bg-secondary);
}
.v2-container {
  max-width: 1280px;
  margin: 0 auto;
}
.v2-section-title {
  font-size: 2.2rem;
  font-weight: 800;
  margin-bottom: 48px;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 16px;
  letter-spacing: -0.5px;
}
.v2-section-title::after {
  content: '';
  flex: 1;
  height: 2px;
  background: linear-gradient(to right, var(--bg-card), transparent);
  border-radius: 2px;
}
.v2-section-title span.badge {
  font-size: 0.9rem;
  background: var(--accent-glow);
  color: var(--accent-light);
  padding: 4px 12px;
  border-radius: 20px;
  font-weight: 600;
  letter-spacing: normal;
}

/* --- Masonry/Grid Cards --- */
.v2-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 30px;
}
.v2-card {
  background: var(--bg-primary);
  border: 1px solid var(--bg-card);
  border-radius: 20px;
  padding: 32px 28px;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}
.v2-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; width: 100%; height: 4px;
  background: var(--accent-gradient);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s ease;
}
.v2-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px var(--accent-glow);
  border-color: rgba(255,255,255,0.08);
}
.v2-card:hover::before {
  transform: scaleX(1);
}
.v2-card-cat {
  display: inline-block;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--accent-light);
  margin-bottom: 16px;
  font-weight: 800;
  background: var(--accent-glow);
  padding: 6px 12px;
  border-radius: 6px;
  width: max-content;
}
.v2-card-title {
  font-size: 1.35rem;
  color: var(--text-primary);
  margin-bottom: 24px;
  line-height: 1.4;
  font-weight: 700;
  flex: 1;
}
.v2-card-action {
  font-size: 0.9rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 8px;
  transition: color 0.3s ease;
}
.v2-card:hover .v2-card-action {
  color: var(--accent-light);
}
.v2-card-action i {
  transition: transform 0.3s ease;
  font-style: normal;
}
.v2-card:hover .v2-card-action i {
  transform: translateX(6px);
}

/* --- Pagination (Reused logic, V2 styles) --- */
.v2-pagination {
  margin-top: 60px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
}
.v2-page-btn {
  padding: 12px 24px;
  border-radius: 30px;
  background: var(--bg-card);
  color: var(--text-primary);
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
  border: 1px solid transparent;
}
.v2-page-btn:hover:not(.disabled) {
  background: var(--accent-glow);
  color: var(--accent-light);
  border-color: var(--accent);
}
.v2-page-btn.disabled {
  opacity: 0.4;
  cursor: not-allowed;
}
.v2-page-info {
  font-size: 0.95rem;
  color: var(--text-secondary);
}
.v2-page-info strong {
  color: var(--text-primary);
}

/* --- Category Grid --- */
.v2-cat-section {
  background: var(--bg-primary);
  padding: 80px 20px;
}
.v2-cat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 20px;
}
.v2-cat-card {
  padding: 24px;
  background: var(--bg-secondary);
  border-radius: 16px;
  text-decoration: none;
  transition: all 0.3s ease;
  border: 1px solid var(--bg-card);
  display: flex;
  align-items: center;
  gap: 16px;
}
.v2-cat-card:hover {
  background: var(--bg-card);
  border-color: var(--accent);
  transform: translateY(-4px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}
.v2-cat-icon {
  font-size: 2rem;
  background: var(--accent-glow);
  width: 50px; height: 50px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 12px;
}
.v2-cat-info {
  flex: 1;
}
.v2-cat-card h3 {
  color: var(--text-primary);
  font-size: 1.15rem;
  margin-bottom: 4px;
  font-weight: 700;
}
.v2-cat-card p {
  color: var(--text-secondary);
  font-size: 0.85rem;
}
</style>
`);

// 2. Hero Section
html.push(`
<section class="v2-hero" id="v2-hero">
  <div class="v2-hero-content">
    <h1 class="v2-hero-title">Unlock <span class="hg">${totalCount.toLocaleString()}+</span> Articles in Seconds</h1>
    <p class="v2-hero-subtitle">The ultimate knowledge base, engineered for speed and depth. Discover precisely what you need.</p>
    <form action="/search" method="GET" class="v2-search-form">
      <div class="v2-search-wrapper">
        <svg fill="none" stroke="var(--text-muted)" stroke-width="2" width="22" height="22" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" name="q" class="v2-search-input" placeholder="Search any topic, phrase, or keyword..." autocomplete="off" required>
        <button type="submit" class="v2-search-btn">Discover</button>
      </div>
    </form>
  </div>
</section>
`);

// 3. Featured Articles
html.push(`
<section class="v2-section" id="featured">
  <div class="v2-container">
    <h2 class="v2-section-title">Editor's Picks <span class="badge">Featured</span></h2>
    <div class="v2-grid">
`);

articles.forEach(function(a) {
  html.push(`
      <a href="${buildArticleUrl(a.f1, a.f2, a.code, a.keyword)}" class="v2-card">
        <div class="v2-card-cat">${a.f1}</div>
        <h3 class="v2-card-title">${a.keyword}</h3>
        <div class="v2-card-action">Read Insight <i>→</i></div>
      </a>
  `);
});

html.push(`    </div>`); // End v2-grid

// 4. Pagination
if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) {
  html.push(`
    <nav class="v2-pagination">
      ${pagination.hasPrev ? `<a href="${pagination.prevUrl}" class="v2-page-btn">← Prev</a>` : `<span class="v2-page-btn disabled">← Prev</span>`}
      <span class="v2-page-info">Page <strong>${pagination.page}</strong> of <strong>${pagination.totalPages.toLocaleString()}</strong></span>
      ${pagination.hasNext ? `<a href="${pagination.nextUrl}" class="v2-page-btn">Next →</a>` : `<span class="v2-page-btn disabled">Next →</span>`}
    </nav>
  `);
}

html.push(`
  </div>
</section>
`);

// 5. Categories
html.push(`
<section class="v2-cat-section" id="categories">
  <div class="v2-container">
    <h2 class="v2-section-title">Explore Hubs</h2>
    <div class="v2-cat-grid">
`);

folders.forEach(function(f) {
  html.push(`
      <a href="/page/${f.f1}" class="v2-cat-card">
        <div class="v2-cat-icon">📁</div>
        <div class="v2-cat-info">
          <h3>${f.f1.toUpperCase()}</h3>
          <p>${f.totalArticles.toLocaleString()} Resources</p>
        </div>
      </a>
  `);
});

html.push(`
    </div>
  </div>
</section>
`);

var cb = html.join('\n');
%>

<%- include('../layouts/main', { contentBlock: cb }) %>
