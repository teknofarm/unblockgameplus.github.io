<%
var contentBlock = '';

contentBlock += '<section class="category-page" id="category-page"><div class="container">';

// Breadcrumb
contentBlock += '<nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a>';
if (f1) contentBlock += '<span class="sep">›</span><a href="/page/' + f1 + '">' + f1 + '</a>';
if (f2) contentBlock += '<span class="sep">›</span><span class="current">' + f2 + '</span>';
contentBlock += '</nav>';

// Header
contentBlock += '<header class="category-header"><h1 class="category-title">' +
  (f2 ? 'Category: ' + f1 + ' / ' + f2 : 'Category: ' + f1) + '</h1>' +
  '<p class="category-desc">' + totalArticles.toLocaleString() + ' articles available</p></header>';

// Subfolders grid
if (subfolders && subfolders.length > 0) {
  contentBlock += '<div class="subcategory-grid">';
  subfolders.forEach(function(s) {
    contentBlock += '<a href="/page/' + s.f1 + '/' + s.f2 + '" class="subcat-card"><div class="subcat-icon">📂</div>' +
      '<h3>' + s.f2 + '</h3><p>' + s.count.toLocaleString() + ' articles</p></a>';
  });
  contentBlock += '</div>';
}

// Articles list
if (articles && articles.length > 0) {
  contentBlock += '<div class="article-list">';
  articles.forEach(function(a) {
    contentBlock += '<article class="list-item"><a href="' + buildArticleUrl(a.f1, a.f2, a.code, a.keyword) + '"><h3>' + a.keyword + '</h3>' +
      '<span class="list-meta">' + a.f1 + '/' + a.f2 + '</span><span class="list-arrow">→</span></a></article>';
  });
  contentBlock += '</div>';
}

// Pagination
if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) {
  contentBlock += '<nav class="pagination" aria-label="Page navigation">';
  if (pagination.hasPrev) {
    contentBlock += '<a href="' + pagination.prevUrl + '" class="page-btn prev" rel="prev">← Previous</a>';
  } else {
    contentBlock += '<span class="page-btn prev disabled">← Previous</span>';
  }
  contentBlock += '<span class="page-info">Page <strong>' + pagination.page + '</strong> of <strong>' + pagination.totalPages + '</strong></span>';
  if (pagination.hasNext) {
    contentBlock += '<a href="' + pagination.nextUrl + '" class="page-btn next" rel="next">Next →</a>';
  } else {
    contentBlock += '<span class="page-btn next disabled">Next →</span>';
  }
  contentBlock += '</nav>';
}

contentBlock += '</div></section>';
%>

<%- include('../layouts/main', { contentBlock: contentBlock }) %>
