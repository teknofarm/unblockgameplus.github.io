<!-- I'm Human Security Verification Popup -->
<div class="popup-overlay" id="popup-overlay">
  <div class="popup-card" id="popup-card">
    <div class="popup-header">
      <div class="popup-shield">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="m9 12 2 2 4-4" stroke-width="2"/>
        </svg>
      </div>
      <h3>Security Check</h3>
      <p>Please verify you are a human to continue browsing</p>
    </div>

    <div class="popup-spinner" id="popup-spinner">
      <div class="spinner"></div>
      <span>Verifying your connection...</span>
    </div>

    <button class="popup-btn" id="popup-btn" disabled>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m9 12 2 2 4-4"/>
        <circle cx="12" cy="12" r="10"/>
      </svg>
      I'm Human
    </button>

    <p class="popup-note">This check helps protect our site from automated access</p>
  </div>
</div>

<script>
(function() {
  var COOLDOWN_KEY = 'agc_human_verified';
  var COOLDOWN_HOURS = <%= config.ads.popup.cooldownHours || 24 %>;
  var DELAY_SECONDS = <%= config.ads.popup.delaySeconds || 3 %>;
  var DIRECT_LINK = '<%= config.ads.directLinkUrl %>';

  // Check cooldown (Reset if > 1 minute / 60000ms as per user request)
  var RESET_MS = 60000; 

  function checkAndShow() {
    var lastVerified = localStorage.getItem(COOLDOWN_KEY);
    if (lastVerified) {
      var elapsed = Date.now() - parseInt(lastVerified);
      var cooldownMs = COOLDOWN_HOURS * 3600000;
      if (elapsed < cooldownMs) {
        // Still in cooldown — hide popup if it was showing
        document.getElementById('popup-overlay').style.display = 'none';
        document.body.style.overflow = '';
        return;
      }
    }

    // Show popup
    showPopup();
  }

  function showPopup() {
    var overlay = document.getElementById('popup-overlay');
    var btn = document.getElementById('popup-btn');
    var spinner = document.getElementById('popup-spinner');

    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    btn.disabled = true;
    btn.classList.remove('ready');
    spinner.style.display = 'block';

    // Enable button after delay
    setTimeout(function() {
      spinner.style.display = 'none';
      btn.disabled = false;
      btn.classList.add('ready');
    }, DELAY_SECONDS * 1000);
  }

  // Initial check
  checkAndShow();

  // Re-check every 10 seconds to catch the 1-minute expiration while staying on page
  setInterval(checkAndShow, 10000);

  document.getElementById('popup-btn').addEventListener('click', function() {
    localStorage.setItem(COOLDOWN_KEY, Date.now().toString());
    document.body.style.overflow = '';
    document.getElementById('popup-overlay').style.display = 'none';

    // Open direct link
    if (DIRECT_LINK) {
      window.open(DIRECT_LINK, '_blank');
    }
  });
})();
</script>
